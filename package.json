{
  "name": "data-form-app",
  "version": "1.0.0",
  "private": true,
  "description": "Data Form App — monorepo (NestJS API + React web)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w @data-form/api",
    "dev:web": "npm run dev -w @data-form/web",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build -w @data-form/api && npm run build -w @data-form/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
